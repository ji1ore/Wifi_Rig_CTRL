<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Fixed header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#111111">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="APRS Settings"
            android:textColor="#00FFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btnOk"
            android:layout_width="80dp"
            android:layout_height="36dp"
            android:text="OK"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <!-- Scrollable settings list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- APRS Enabled -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="APRS Enabled" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <Switch android:id="@+id/switchAprsEnabled" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Use GPS -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Use GPS" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <Switch android:id="@+id/switchUseGps" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Latitude -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Latitude" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <EditText android:id="@+id/editLat"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/edit_bg" android:textColor="#FFFFFF"
                android:inputType="numberDecimal|numberSigned" android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <!-- Longitude -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Longitude" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <EditText android:id="@+id/editLon"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/edit_bg" android:textColor="#FFFFFF"
                android:inputType="numberDecimal|numberSigned" android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <!-- TX Freq -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="APRS TX Freq (MHz)" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <EditText android:id="@+id/editTxFreq"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/edit_bg" android:textColor="#FFFFFF"
                android:inputType="numberDecimal" android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <!-- Baud (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Baud Rate" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvBaud"
                    android:layout_width="120dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
            </LinearLayout>

            <!-- Interval (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="TX Interval" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvInterval"
                    android:layout_width="120dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
            </LinearLayout>

            <!-- Callsign -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Callsign" android:textColor="#AAAAAA" android:textSize="12sp"/>
            <EditText android:id="@+id/editCallsign"
                android:layout_width="match_parent" android:layout_height="44dp"
                android:background="@drawable/edit_bg" android:textColor="#FFFFFF"
                android:inputType="text" android:padding="10dp"
                android:layout_marginBottom="8dp"/>

            <!-- SSID (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="SSID (-N)" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvSSID"
                    android:layout_width="120dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
            </LinearLayout>

            <!-- Path (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Path" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvPath"
                    android:layout_width="160dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Symbol (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Symbol" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvSymbol"
                    android:layout_width="120dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="14sp"/>
            </LinearLayout>

            <!-- Destination (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Destination" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvDestination"
                    android:layout_width="120dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Sound Device (toggle) -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Sound Device" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <TextView android:id="@+id/tvSoundDevice"
                    android:layout_width="160dp" android:layout_height="36dp"
                    android:background="@drawable/edit_bg" android:gravity="center"
                    android:textColor="#FFFFFF" android:textSize="11sp"
                    android:ellipsize="end" android:maxLines="1"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>