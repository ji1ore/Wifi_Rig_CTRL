<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PTT Settings"
        android:textColor="#00FFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="PTT Method" android:textColor="#AAAAAA" android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="20dp">
        <Button
            android:id="@+id/btnWifiPtt"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Wifi_PTT"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />
        <Button
            android:id="@+id/btnHamlibPtt"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Hamlib"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="PTT Host (mDNS or IP)" android:textColor="#AAAAAA" android:textSize="12sp"/>
    <EditText
        android:id="@+id/editPttHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edit_bg"
        android:textColor="#FFFFFF"
        android:hint="e.g. wifiptt.local"
        android:textColorHint="#666666"
        android:inputType="text"
        android:padding="10dp"
        android:layout_marginBottom="16dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="PTT Port" android:textColor="#AAAAAA" android:textSize="12sp"/>
    <EditText
        android:id="@+id/editPttPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edit_bg"
        android:textColor="#FFFFFF"
        android:hint="5198"
        android:textColorHint="#666666"
        android:inputType="number"
        android:padding="10dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnOk"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="OK"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>
